generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User Model (Student & Admin)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("student") // 'admin' or 'student'
  createdAt DateTime @default(now())
  
  // Relations
  results   Result[]
  batchId   String?
  batch     Batch?   @relation(fields: [batchId], references: [id])
}

// 2. Batch Model (For Grouping Students)
model Batch {
  id        String   @id @default(uuid())
  name      String
  users     User[]
  testIds   String[] // List of Test IDs assigned to this batch
}

// 3. Test Model (IELTS Exam Paper)
model Test {
  id          String   @id @default(uuid())
  title       String
  type        String   // 'reading', 'listening', 'writing', 'speaking'
  timeLimit   Int      // In minutes
  
  // Content: Passage text (Reading) or Audio URL (Listening)
  content     Json?    
  
  // Questions: The complex IELTS questions (MCQ, Fill gaps etc.)
  questions   Json     
  
  createdAt   DateTime @default(now())
  results     Result[]
}

// 4. Result Model (Student Marks)
model Result {
  id          String   @id @default(uuid())
  score       Float?
  
  // Answers given by student
  answers     Json     
  
  feedback    String?
  submittedAt DateTime @default(now())

  // Relations
  studentId   String
  student     User     @relation(fields: [studentId], references: [id])
  testId      String
  test        Test     @relation(fields: [testId], references: [id])
}
